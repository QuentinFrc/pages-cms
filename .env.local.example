# BASE_URL="https://mycustomdomain.com" # In production, set this to the single canonical app URL. On Vercel, scope it per environment (e.g. Production: https://cms.example.com, Preview: https://cms-preview.example.com); when unset it falls back to the deployment URL.
# AUTH_ALLOWED_HOSTS="cms-preview.example.com,*.example.com" # Optional. Extra hosts (comma-separated, wildcards allowed) allowed to serve auth besides BASE_URL's host. *.vercel.app is added automatically on Vercel.
# ADMIN_EMAILS="admin@example.com,other-admin@example.com"
# SINGLE_PROJECT=true # Optional. Lock this deployment to a single connected project. The project is discovered from the first configured repo; "/" redirects into it and project-picker / repo-switcher UI is hidden.
BETTER_AUTH_SECRET="random-string-of-characters"
CRYPTO_KEY="random-string-of-characters"
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_NAME="your-github-app-machine-name"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
xxx
-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET="another-random-string-of-characters"
GITHUB_APP_CLIENT_ID="your-github-app-client-id"
GITHUB_APP_CLIENT_SECRET="your-github-app-client-secret"
# EMAIL_PROVIDER="resend" # or "smtp"
EMAIL_FROM="Pages CMS <no-reply@mail.pagescms.org>"
# Resend config
# RESEND_API_KEY="your-resend-api-key"
# RESEND_FROM_EMAIL="Pages CMS <no-reply@mail.pagescms.org>" # backwards-compatible alias for EMAIL_FROM
# SMTP config
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
DATABASE_URL="postgresql://pagescms:pagescms@localhost:5432/pagescms"
# CACHE_CHECK_MIN=5
# CONFIG_CHECK_MIN=5
# FILE_TTL_MIN=1440
# PERMISSIONS_TTL_MIN=60
# BRANCH_HEAD_TTL_MS=15000
# REPO_META_TTL_MS=15000
# Webhook push processing thresholds
# <= WEBHOOK_PUSH_INCREMENTAL_MAX_FILES: incremental cache updates
# > WEBHOOK_PUSH_INCREMENTAL_MAX_FILES and <= WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES: scoped cache invalidation
# > WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES: full branch cache invalidation
# WEBHOOK_PUSH_INCREMENTAL_MAX_FILES=120
# WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES=800

# Shared app port (dev, start, tunnel, setup:github-app)
PORT=3000

# Stable named tunnel (optional — see scripts/dev-tunnel.mjs)
# TUNNEL_HOSTNAME=cms-dev.example.com
# TUNNEL_NAME=pagescms-dev

# Redirect localhost -> BASE_URL (tunnel); disable when working without the tunnel
# DEV_REDIRECT_TO_BASE_URL=true

# Extra dev origins for next dev (comma-separated, wildcards allowed).
# Required for quick tunnels, whose hostname changes on every start:
# ALLOWED_DEV_ORIGINS=*.trycloudflare.com
